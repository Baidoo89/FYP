# Production environment template (Neon PostgreSQL)
# Copy values into your hosting provider's environment settings.

NODE_ENV=production
NEXT_PUBLIC_API_URL=https://your-production-domain.com

# Prisma datasource (Neon)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxx.us-east-1.aws.neon.tech/DBNAME?sslmode=require

# Session/auth
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=gctu_session

# Optional fallback local admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-in-production
