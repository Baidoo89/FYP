# Production environment template (Neon PostgreSQL)
# Copy values into your hosting provider's environment settings.

# Runtime
NODE_ENV=production
NEXT_PUBLIC_API_URL=https://your-production-domain.com

# Prisma datasource (Neon)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxx.us-east-1.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require

# Auth signing secret (app uses AUTH_SECRET first, NEXTAUTH_SECRET fallback)
AUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Fallback local admin credentials (used if DB fallback path is hit)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
